msgstr "plugin.php bevat geen geldige YOURLS-plugin-header."

msgid "plugin.php not found in final plugin directory."
msgstr "plugin.php niet gevonden in de uiteindelijke plugin-map."

msgid "Repository"
msgstr "Repository"

msgid "Repository associated successfully."
msgstr "Repository succesvol gekoppeld."

msgid "Repository associated successfully. No release/tag is available yet; update checks may fail until one is published."
msgstr "Repository succesvol gekoppeld. Er is nog geen release of tag beschikbaar; updatecontroles kunnen mislukken totdat er een gepubliceerd is."

msgid "Repository association not needed for default plugins."
msgstr "Repository-koppeling is niet nodig voor standaard plugins."

