msgstr "Fouten"

msgid "Extraction failed: unable to extract ZIP archive."
msgstr "Uitpakken mislukt: kan het ZIP-archief niet uitpakken."

msgid "Extraction failed: unable to open ZIP archive."
msgstr "Uitpakken mislukt: kan het ZIP-archief niet openen."

msgid "Failed to delete plugin."
msgstr "Verwijderen van plugin mislukt."

msgid "Failed to move extracted plugin directory."
msgstr "Verplaatsen van uitgepakte plugin-map mislukt."

msgid "Failed to replace existing plugin directory."
msgstr "Vervangen van bestaande plugin-map mislukt."

