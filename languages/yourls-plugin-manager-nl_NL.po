msgstr "Sluiten"

msgid "Create a new GitHub token"
msgstr "Nieuw GitHub-token aanmaken"

msgid "Custom links-per-page value removed. YOURLS default is now active."
msgstr "Aangepaste waarde voor links-per-pagina verwijderd. De YOURLS-standaard is nu actief."

msgid "Custom links-per-page value saved."
msgstr "Aangepaste waarde voor links-per-pagina opgeslagen."

msgid "Default plugins do not require repository association."
msgstr "Standaard plugins hebben geen repository-koppeling nodig."

